import torch
from torch import nn
import tool


def MLE_mnist(num_input, num_hid, num_output, lr, num_epochs):
    # model (one hidden ,relu)
    net = nn.Sequential(nn.Flatten(),
                    nn.Linear(num_input, num_hid),
                    nn.ReLU(),
                    nn.Linear(num_hid, num_output)

        )
    
    def init_weights(m):
        if type(m) == nn.Linear:
            nn.init.normal_(m.weight, std = 0.01)

    net.apply(init_weights)

    loss = nn.CrossEntropyLoss(reduction='none')

    trainer = torch.optim.SGD(net.parameters(), lr=lr)
    # data
    train_iter, test_iter = tool.load_data_fashion_mnist(batch_size=256)

    # training
    tool.train_ch3(train_iter=train_iter, test_iter=test_iter, loss=loss, num_epochs=num_epochs, trainer=trainer)

   
MLE_mnist(num_input=784, num_hid=256, num_output=10, lr=0.1, num_epochs=10 )
    





